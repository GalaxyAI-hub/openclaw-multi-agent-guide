# 飞书配置文件

> ⚠️ 敏感信息，不要提交到 Git

# ========== 飞书应用配置 ==========
# 1. 打开 https://open.feishu.cn/
# 2. 创建"企业自建应用"
# 3. 复制 App ID 和 App Secret
APP_ID=your_app_id_here
APP_SECRET=your_app_secret_here

# ========== 目标文件夹 ==========
# 1. 在飞书中创建一个文件夹
# 2. 打开文件夹，复制浏览器 URL 中的 folder_token
#    URL 格式: https://xxx.feishu.cn/wiki/...?folder=xxxxx
#    folder_token 就是 xxxx 部分
FOLDER_TOKEN=your_folder_token_here

# ========== 文档配置 ==========
# 文档标题前缀
DOC_PREFIX=【Multi-Agent新手指南】

# 是否创建索引文档
CREATE_INDEX=true
